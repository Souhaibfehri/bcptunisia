# =============================================================================
# reCAPTCHA Enterprise — one project, one site key, one Google Cloud API key
# =============================================================================
#
# Used by:
#   - Public lead/contact form (visible checkbox) → POST /api/contact
#   - Portal email/password login & signup preflight → POST /api/recaptcha/verify
#   - Forgot-password request → POST /api/auth/forgot-password
#   - Admin invite / create user (server actions) → assertRecaptchaFromFormData
#
# RECAPTCHA_API_KEY must be the KEY STRING from Google Cloud (APIs & Services →
# Credentials → API key), with "reCAPTCHA Enterprise API" enabled. It looks like AIza...
# NEVER paste the full URL https://recaptchaenterprise.googleapis.com/... here.
#
# -----------------------------------------------------------------------------

# Shown in the browser (checkbox + score execute). Must match the key in Google Cloud reCAPTCHA.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Google Cloud project id (same as in the assessments URL path).
RECAPTCHA_PROJECT_ID=

# Optional: only if you need a different string for server-side event.siteKey (must match widget if set).
RECAPTCHA_SITE_KEY=

# Primary: Google Cloud API key for .../assessments?key=YOUR_KEY_HERE
RECAPTCHA_API_KEY=

# Fallback alias (same role as RECAPTCHA_API_KEY for REST assessments).
RECAPTCHA_SECRET_KEY=

# Score thresholds (LOGIN, SIGNUP, RESET_PASSWORD_REQUEST, CREATE_USER, INVITE_USER only).
# Public lead checkbox does not use score checks.
RECAPTCHA_MIN_SCORE_LOGIN=0.5
RECAPTCHA_MIN_SCORE_SIGNUP=0.5
RECAPTCHA_MIN_SCORE_RESET_PASSWORD_REQUEST=0.5
RECAPTCHA_MIN_SCORE_CONTACT_FORM=0.4
RECAPTCHA_MIN_SCORE_CREATE_USER=0.5
RECAPTCHA_MIN_SCORE_INVITE_USER=0.5
