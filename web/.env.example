# --- reCAPTCHA Enterprise (public lead form = checkbox; portal = score execute) ---

# Site key in the browser (LeadForm checkbox). Do not put secrets here.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Google Cloud project id (REST: .../v1/projects/{id}/assessments)
RECAPTCHA_PROJECT_ID=

# Optional override for CreateAssessment event.siteKey. If set, must match NEXT_PUBLIC_RECAPTCHA_SITE_KEY (same key as the widget).
RECAPTCHA_SITE_KEY=

# Server-only: Google Cloud API key for assessments URL ?key= (reCAPTCHA Enterprise API enabled). Never expose to client.
RECAPTCHA_API_KEY=
# Optional alias (same use as RECAPTCHA_API_KEY for this endpoint; login/signup score flow may still read it first from config).
RECAPTCHA_SECRET_KEY=

# Optional score thresholds (login/signup/etc. only; public lead checkbox does not use score)
RECAPTCHA_MIN_SCORE_LOGIN=0.5
RECAPTCHA_MIN_SCORE_SIGNUP=0.5
RECAPTCHA_MIN_SCORE_RESET_PASSWORD_REQUEST=0.5
RECAPTCHA_MIN_SCORE_CONTACT_FORM=0.4
RECAPTCHA_MIN_SCORE_CREATE_USER=0.5
RECAPTCHA_MIN_SCORE_INVITE_USER=0.5
