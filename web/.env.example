# Sanity CMS — BCP Tunisia (defaults are baked in; override here for another project/dataset)
NEXT_PUBLIC_SANITY_PROJECT_ID=rbaoo9sa
NEXT_PUBLIC_SANITY_DATASET=production

# Optional: override form recipient server-side (takes precedence over Sanity « Réglages site »)
# CONTACT_FORM_RECIPIENT=contact@bcptunisia.com

# Studio (embedded in Next): http://localhost:3010/studio (see package.json dev port)
# Manage project: https://www.sanity.io/manage

# Public site URL (no trailing slash) for Supabase auth (OAuth, signup, reset, admin invites).
# Prefer NEXT_PUBLIC_APP_URL; if unset, NEXT_PUBLIC_SITE_URL is used. Local dev falls back to http://localhost:3010 when both are empty.
# NEXT_PUBLIC_APP_URL=https://darkgoldenrod-emu-199621.hostingersite.com
# NEXT_PUBLIC_SITE_URL=

# Supabase — client portal & admin (see PORTAL_SETUP.md)
# URL must match the same project as the keys (Dashboard → Settings → API → Project URL).
NEXT_PUBLIC_SUPABASE_URL=
# At least one public key is required. Prefer the anon legacy JWT (eyJ…) in NEXT_PUBLIC_SUPABASE_ANON_KEY
# if signup shows "Failed to fetch" or auth errors.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (invitations, direct user creation, notifications insert). Never NEXT_PUBLIC_*.
# Use either name — same service_role JWT from Dashboard → Settings → API.
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SECRET_KEY=
