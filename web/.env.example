# --- reCAPTCHA Enterprise (score) — optional locally; omit to skip verification ---
# Public site key (browser + assessment body)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Google Cloud project id (server)
RECAPTCHA_PROJECT_ID=

# Server-only: API key for `recaptchaenterprise.googleapis.com/.../assessments?key=` (never expose to client)
# Alternative name supported in code: RECAPTCHA_API_KEY
RECAPTCHA_SECRET_KEY=

# Optional score thresholds (0.0–1.0)
RECAPTCHA_MIN_SCORE_LOGIN=0.5
RECAPTCHA_MIN_SCORE_SIGNUP=0.5
RECAPTCHA_MIN_SCORE_RESET_PASSWORD_REQUEST=0.5
RECAPTCHA_MIN_SCORE_CONTACT_FORM=0.4
RECAPTCHA_MIN_SCORE_CREATE_USER=0.5
RECAPTCHA_MIN_SCORE_INVITE_USER=0.5
