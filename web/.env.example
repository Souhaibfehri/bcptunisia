# --- Public lead form: visible reCAPTCHA Enterprise checkbox ---
# Shown in the browser (LeadForm). Do not put secrets here.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Google Cloud project (server-side CreateAssessment)
RECAPTCHA_PROJECT_ID=

# Site key sent in CreateAssessment (server). Prefer this over public var on the server.
# Falls back to NEXT_PUBLIC_RECAPTCHA_SITE_KEY if unset.
RECAPTCHA_SITE_KEY=

# Path to service account JSON for reCAPTCHA Enterprise API (server only).
# See: https://cloud.google.com/docs/authentication/application-default-credentials
GOOGLE_APPLICATION_CREDENTIALS=

# Optional alias supported by the Google client libraries
# GOOGLE_CLOUD_KEY_FILE=

# --- Other flows (login, signup, forgot password, admin): score-based Enterprise ---
# API key for REST assessments (never expose to client). Not used by the public lead checkbox path.
RECAPTCHA_SECRET_KEY=
# or: RECAPTCHA_API_KEY=

RECAPTCHA_MIN_SCORE_LOGIN=0.5
RECAPTCHA_MIN_SCORE_SIGNUP=0.5
RECAPTCHA_MIN_SCORE_RESET_PASSWORD_REQUEST=0.5
RECAPTCHA_MIN_SCORE_CONTACT_FORM=0.4
RECAPTCHA_MIN_SCORE_CREATE_USER=0.5
RECAPTCHA_MIN_SCORE_INVITE_USER=0.5
